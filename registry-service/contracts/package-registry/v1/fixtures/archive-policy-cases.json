{
  "contract_version": 1,
  "policy": "archive-policy-v1.json",
  "case_schema": "../schemas/archive-validation-case-v1.schema.json",
  "cases": [
    {
      "name": "minimal_source_archive",
      "description": "A source-only package with a regular manifest and Seen source is accepted.",
      "archive": {
        "format": "tar+gzip",
        "parser_result": "complete",
        "stats": {"compressed_bytes": 2048, "expanded_bytes": 8192, "entry_count": 3, "max_regular_file_bytes": 4096, "max_path_bytes": 18, "max_path_depth": 2, "compression_ratio": 4},
        "entries": [
          {"header_path": "Seen.toml", "effective_path": "Seen.toml", "type": "regular-file", "size": 512, "mode": "0644", "included_by_manifest": true, "header_override": "none"},
          {"header_path": "src", "effective_path": "src", "type": "directory", "size": 0, "mode": "0755", "included_by_manifest": true, "header_override": "none"},
          {"header_path": "src/main.seen", "effective_path": "src/main.seen", "type": "regular-file", "size": 4096, "mode": "0644", "included_by_manifest": true, "header_override": "none"}
        ]
      },
      "expected": "accept"
    },
    {
      "name": "parent_traversal",
      "description": "A parent segment is rejected before extraction.",
      "archive": {
        "format": "tar+gzip", "parser_result": "complete",
        "stats": {"compressed_bytes": 1024, "expanded_bytes": 2048, "entry_count": 2, "max_regular_file_bytes": 1024, "max_path_bytes": 18, "max_path_depth": 2, "compression_ratio": 2},
        "entries": [
          {"header_path": "Seen.toml", "effective_path": "Seen.toml", "type": "regular-file", "size": 512, "mode": "0644", "included_by_manifest": true, "header_override": "none"},
          {"header_path": "../escape.seen", "effective_path": "../escape.seen", "type": "regular-file", "size": 1024, "mode": "0644", "included_by_manifest": true, "header_override": "none"}
        ]
      },
      "expected": "reject", "error_code": "archive_path_traversal", "failure_entry": 1
    },
    {
      "name": "pax_effective_path_traversal",
      "description": "Validation uses the PAX-overridden effective path, not the benign legacy header path.",
      "archive": {
        "format": "tar+gzip", "parser_result": "complete",
        "stats": {"compressed_bytes": 1024, "expanded_bytes": 2048, "entry_count": 2, "max_regular_file_bytes": 1024, "max_path_bytes": 24, "max_path_depth": 3, "compression_ratio": 2},
        "entries": [
          {"header_path": "Seen.toml", "effective_path": "Seen.toml", "type": "regular-file", "size": 512, "mode": "0644", "included_by_manifest": true, "header_override": "none"},
          {"header_path": "src/looks-safe.seen", "effective_path": "src/../../escape.seen", "type": "regular-file", "size": 1024, "mode": "0644", "included_by_manifest": true, "header_override": "pax-path"}
        ]
      },
      "expected": "reject", "error_code": "archive_path_traversal", "failure_entry": 1
    },
    {
      "name": "posix_absolute_path",
      "description": "A POSIX absolute path is rejected.",
