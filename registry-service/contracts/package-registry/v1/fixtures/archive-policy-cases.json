        "entries": [
          {"header_path": "Seen.toml", "effective_path": "Seen.toml", "type": "regular-file", "size": 512, "mode": "0644", "included_by_manifest": true, "header_override": "none"},
          {"header_path": "/etc/passwd", "effective_path": "/etc/passwd", "type": "regular-file", "size": 1024, "mode": "0644", "included_by_manifest": true, "header_override": "none"}
        ]
      },
      "expected": "reject", "error_code": "archive_path_absolute", "failure_entry": 1
    },
    {
      "name": "windows_absolute_path",
